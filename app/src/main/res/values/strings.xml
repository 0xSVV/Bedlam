    <string name="settings_reliability_risk_high">Action needed</string>
    <string name="settings_reliability_hero_confirmed_title">Reliability checklist completed</string>
    <string name="settings_reliability_hero_confirmed_body">Bedlam will remember this until the phone software changes. If %1$s resets battery settings after an update, this page will ask you to review it again</string>
    <string name="settings_reliability_hero_high_title">This phone may stop Bedlam</string>
    <string name="settings_reliability_hero_high_body">%1$s can apply extra battery rules beyond Android battery optimization. Review the checklist before relying on the tunnel with the screen off</string>
    <string name="settings_reliability_hero_medium_title">A reliability check is recommended</string>
    <string name="settings_reliability_hero_medium_body">%1$s may limit long-running background apps on some firmware builds. These settings make the tunnel less likely to be stopped</string>
    <string name="settings_reliability_hero_low_title">This device looks normal</string>
    <string name="settings_reliability_hero_low_body">%1$s is not known to need aggressive vendor workarounds. You can still enable Always-on VPN for easier recovery after reboots</string>
    <string name="settings_reliability_checklist_title">Checklist</string>
    <string name="settings_reliability_checklist_body">These are the settings that matter for a foreground VPN service. Some can be opened directly; vendor battery pages still need a manual tap</string>
    <string name="settings_reliability_check_battery_title">Android battery optimization</string>
    <string name="settings_reliability_check_battery_body">Allows Bedlam to keep network access and its wake lock during Doze</string>
    <string name="settings_reliability_check_vendor_title">Vendor background activity</string>
    <string name="settings_reliability_check_vendor_body_risky">%1$s has an extra app battery policy that can stop VPNs even after Android battery optimization is allowed</string>
    <string name="settings_reliability_check_vendor_body_normal">%1$s usually does not need an extra vendor-specific battery setting for a foreground VPN</string>
    <string name="settings_reliability_check_restricted_title">Android background restriction</string>
    <string name="settings_reliability_check_restricted_body">Current standby bucket: %1$s. Restricted apps may lose background work even when a service is visible</string>
    <string name="settings_reliability_check_notifications_title">VPN notification</string>
    <string name="settings_reliability_check_notifications_body">Android requires Bedlam to keep a visible notification while the tunnel is active</string>
    <string name="settings_reliability_check_always_on_title">Always-on VPN</string>
    <string name="settings_reliability_check_always_on_body">Lets Android restart Bedlam after boot or system restarts. Enable lockdown only if you want all traffic blocked until the tunnel is up</string>
