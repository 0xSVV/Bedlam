    <string name="settings_reliability_vendor_title">%1$s steps</string>
    <string name="settings_reliability_vendor_body_oneplus">On OxygenOS, start with App info -> Battery usage, then also check Sleep standby optimization, Deep optimization, and Recents lock if the tunnel still stops</string>
    <string name="settings_reliability_vendor_body_coloros">ColorOS and realme UI often split this into background activity, foreground activity, autostart, and Recents lock. Enable every one that is visible</string>
    <string name="settings_reliability_vendor_body_xiaomi">MIUI and HyperOS often require both No restrictions and Autostart. Some builds also stop apps that are not locked in Recents</string>
    <string name="settings_reliability_vendor_body_huawei">EMUI and MagicOS usually require manual app launch management. Enable every launch/background toggle for Bedlam</string>
    <string name="settings_reliability_vendor_body_vivo">vivo and iQOO firmware commonly separates autostart from background power use. Bedlam needs both allowed</string>
    <string name="settings_reliability_vendor_body_generic_aggressive">This vendor sometimes adds extra battery managers. Look for background activity, autostart, protected apps, or battery saver for Bedlam</string>
    <string name="settings_reliability_vendor_body_samsung">Samsung is usually fine for foreground VPNs. Only use these steps if the phone starts sleeping Bedlam</string>
    <string name="settings_reliability_vendor_body_normal">No special vendor setting was detected. Keep Android battery optimization allowed and use Always-on VPN if you want automatic restart</string>
    <string name="settings_reliability_explain_title">Why Bedlam cannot do this automatically</string>
    <string name="settings_reliability_explain_body">Android lets Bedlam request the standard battery exception, but many vendors add private battery managers with no public API. Bedlam can open nearby settings and explain the path; only you can approve the vendor-specific switch</string>

    <string-array name="settings_reliability_steps_oneplus">
        <item>Open Bedlam app info</item>
        <item>Tap Battery usage or Battery</item>
        <item>Select Unrestricted or Allow background activity</item>
        <item>Disable Sleep standby optimization or Deep optimization if Bedlam still stops</item>
        <item>If visible, lock Bedlam in Recents so OxygenOS does not clear it</item>
    </string-array>
    <string-array name="settings_reliability_steps_coloros">
        <item>Open Bedlam app info</item>
        <item>Open Battery usage or App battery management</item>
        <item>Allow background activity and foreground activity</item>
        <item>Enable Auto launch if the phone shows that switch</item>
        <item>Lock Bedlam in Recents if ColorOS keeps clearing the tunnel</item>
    </string-array>
    <string-array name="settings_reliability_steps_xiaomi">
        <item>Open Bedlam app info</item>
        <item>Open Battery saver and choose No restrictions</item>
        <item>Open Autostart and enable Bedlam</item>
        <item>If the tunnel still stops, lock Bedlam in Recents</item>
    </string-array>
    <string-array name="settings_reliability_steps_huawei">
        <item>Open Battery -> App launch</item>
        <item>Find Bedlam and disable automatic management</item>
        <item>Enable auto-launch, secondary launch, and run in background</item>
        <item>Confirm the changes and reconnect the tunnel</item>
    </string-array>
    <string-array name="settings_reliability_steps_vivo">
        <item>Open Autostart and enable Bedlam</item>
        <item>Open Battery or Background power consumption</item>
        <item>Allow Bedlam to run in background</item>
        <item>Reconnect the tunnel after changing the setting</item>
    </string-array>
    <string-array name="settings_reliability_steps_generic_aggressive">
        <item>Open Bedlam app info</item>
        <item>Set Battery to Unrestricted or No restrictions</item>
        <item>Enable Autostart or Protected app if available</item>
        <item>Allow background activity for Bedlam</item>
    </string-array>
    <string-array name="settings_reliability_steps_samsung">
        <item>Open Bedlam app info</item>
        <item>Set Battery to Unrestricted if Bedlam is being stopped</item>
        <item>In Background usage limits, add Bedlam to Never sleeping apps if needed</item>
    </string-array>
    <string-array name="settings_reliability_steps_normal">
        <item>Allow the Android battery optimization exception</item>
        <item>Enable Always-on VPN if you want automatic restart after boot</item>
        <item>Keep Bedlam notifications allowed while the tunnel is active</item>
    </string-array>
